@model Petly.Models.SuccessStory

@{
    ViewData["Title"] = "Додати історію успіху";
}

<div class="need-page">
    <div class="section-header">
        <div class="section-header__copy">
            <span class="section-kicker">New Success Story</span>
            <h1 class="section-title">Нова щаслива історія</h1>
            <p class="section-subtitle">Поділіться радістю! Розкажіть, як пухнастик знайшов свій дім і нову родину.</p>
        </div>
    </div>

    <section style="display: flex; justify-content: center; padding-bottom: 40px;">
        <article class="need-card" style="width: 100%; max-width: 700px; padding: 40px;">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                <div class="form-group" style="margin-bottom: 24px;">
                    <label asp-for="PetId" style="display: block; font-weight: 600; margin-bottom: 8px; color: #2d3748;"></label>
                    <select asp-for="PetId" class="form-select" asp-items="@(new SelectList(ViewBag.Pets, "PetId", "PetName"))" style="padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0; width: 100%;">
                        <option value="">-- Оберіть пухнастика --</option>
                    </select>
                    <span asp-validation-for="PetId" class="text-danger" style="font-size: 0.875rem; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group" style="margin-bottom: 24px;">
                    <label asp-for="Title" style="display: block; font-weight: 600; margin-bottom: 8px; color: #2d3748;"></label>
                    <input asp-for="Title" class="form-control" placeholder="Наприклад: Барсік знайшов родину!" style="padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0; width: 100%;" />
                    <span asp-validation-for="Title" class="text-danger" style="font-size: 0.875rem; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group" style="margin-bottom: 24px;">
                    <label asp-for="StoryText" style="display: block; font-weight: 600; margin-bottom: 8px; color: #2d3748;"></label>
                    <textarea asp-for="StoryText" class="form-control" rows="5" placeholder="Напишіть кілька слів про те, як пройшла адаптація..." style="padding: 12px; border-radius: 8px; border: 1px solid #e2e8f0; width: 100%; resize: vertical;"></textarea>
                    <span asp-validation-for="StoryText" class="text-danger" style="font-size: 0.875rem; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group" style="margin-bottom: 32px;">
                    <label class="form-label" style="display: block; font-weight: 600; margin-bottom: 8px; color: #2d3748;">Фотографія щасливця</label>
                    <input type="file" name="uploadFile" class="form-control" accept="image/*" style="padding: 10px; border-radius: 8px; border: 1px solid #e2e8f0; width: 100%; background-color: #f8fafc;" />
                </div>

                <div style="display: flex; justify-content: flex-end; gap: 16px; margin-top: 20px; border-top: 1px solid #edf2f7; padding-top: 24px;">
                    <a asp-action="Index" class="btn-need-inline btn-need-inline--danger" style="text-decoration: none;">Скасувати</a>
                    <button type="submit" class="btn-need-inline" style="border: none; cursor: pointer;">Зберегти історію</button>
                </div>
            </form>
        </article>
    </section>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}