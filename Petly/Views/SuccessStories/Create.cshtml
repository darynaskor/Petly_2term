@model Petly.Models.SuccessStory

@{
    ViewData["Title"] = "Додати історію успіху";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">🐾 Додати нову історію</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label asp-for="PetId" class="form-label text-muted fw-bold"></label>
                            <select asp-for="PetId" class="form-select" asp-items="@(new SelectList(ViewBag.Pets, "PetId", "PetName"))">
                                <option value="">-- Оберіть пухнастика --</option>
                            </select>
                            <span asp-validation-for="PetId" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Title" class="form-label text-muted fw-bold"></label>
                            <input asp-for="Title" class="form-control" placeholder="Наприклад: Барсік знайшов свій дім!" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="StoryText" class="form-label text-muted fw-bold"></label>
                            <textarea asp-for="StoryText" class="form-control" rows="5" placeholder="Розкажіть, як пройшло знайомство..."></textarea>
                            <span asp-validation-for="StoryText" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ImageUrl" class="form-label text-muted fw-bold"></label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://посилання-на-фото.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                            <button type="submit" class="btn btn-success">Зберегти історію</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}