@model IEnumerable<Petly.Models.SuccessStory>

@{
    ViewData["Title"] = "Історії успіху";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🏡 Щасливі історії наших пухнастиків</h1>
        <a asp-action="Create" class="btn btn-success">Додати нову історію</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Pet?.PetName">
                    }
                    <div class="card-body">
                        <h5 class="card-title">@item.Title</h5>
                        <p class="text-muted">Герой: <strong>@item.Pet?.PetName</strong></p>
                        <p class="card-text">@item.StoryText.Substring(0, Math.Min(item.StoryText.Length, 100))...</p>
                    </div>
                    <div class="card-footer bg-white border-0">
                        <small class="text-muted">Опубліковано: @item.CreatedAt.ToShortDateString()</small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>