    <div class="app-shell">
        <main role="main" class="pb-3">
            @if (TempData["Success"] is string successMessage)
            {
                <div class="flash-stack">
                    <div class="flash-message flash-message--success" role="alert">
                        <p class="flash-message__text">@successMessage</p>
                        <button type="button" class="flash-message__close" data-dismiss-flash aria-label="Закрити">×</button>
                    </div>
                </div>
            }

            @if (TempData["Error"] is string errorMessage)
            {
                <div class="flash-stack">
                    <div class="flash-message flash-message--error" role="alert">
                        <p class="flash-message__text">@errorMessage</p>
                        <button type="button" class="flash-message__close" data-dismiss-flash aria-label="Закрити">×</button>
                    </div>
                </div>
            }

            @RenderBody()
        </main>
    </div>

