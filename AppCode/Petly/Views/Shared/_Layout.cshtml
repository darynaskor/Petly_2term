                           && (string.Equals(actionName, "Login", System.StringComparison.OrdinalIgnoreCase)
                               || string.Equals(actionName, "Register", System.StringComparison.OrdinalIgnoreCase)
                               || string.Equals(actionName, "ForgotPassword", System.StringComparison.OrdinalIgnoreCase)
                               || string.Equals(actionName, "VerifyResetCode", System.StringComparison.OrdinalIgnoreCase)
                               || string.Equals(actionName, "ResetPassword", System.StringComparison.OrdinalIgnoreCase)));
    }

