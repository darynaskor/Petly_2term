@model List<Petly.Models.Pet>

@{
    ViewData["Title"] = "Головна";
}

<div class="container mt-4">
    @* Кнопки фільтрації *@
    <div class="d-flex gap-2 mb-4 align-items-center">
        <button class="btn btn-filter active">Усі</button>
        <button class="btn btn-filter">Собаки</button>
        <button class="btn btn-filter">Коти</button>
        <button class="btn btn-filter">Прилаштовані</button>
        <div class="input-group ms-auto" style="max-width: 300px;">
            <input type="text" class="form-control rounded-pill border-dark" placeholder="Пошук">
        </div>
    </div>

    @* Сітка карток *@
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var p in Model)
        {
            <div class="col">
                <div class="card h-100 pet-card">
                    @* Перевірка на наявність фото *@
                    <img src="@(string.IsNullOrEmpty(p.PhotoUrl) ? "/images/no-photo.jpg" : p.PhotoUrl)" 
                         class="card-img-top pet-img" alt="@p.PetName">
                    
                    <div class="card-body p-0">
                        <div class="d-flex border-top border-bottom border-dark">
                            <button class="btn btn-pet-action border-end border-dark">Більше</button>
                            <button class="btn btn-pet-action border-end border-dark">Допомога</button>
                            <button class="btn btn-pet-action">Адопція</button>
                        </div>
                        
                        <div class="p-3 bg-light-yellow text-center">
                            <h5 class="mb-0 fw-bold">@p.PetName, @p.Type, @p.Age роки</h5>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>