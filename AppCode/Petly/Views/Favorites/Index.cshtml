@model List<Petly.Models.Favorite>

@{
    ViewData["Title"] = "Обране";
}

<section class="page-section">
    <div class="section-header">
        <div class="section-header__copy">
            <span class="section-kicker">Saved Pets</span>
            <h1 class="section-title">❤️ Моє обране</h1>
            <p class="section-subtitle">Усі тварини, яких ви зберегли, щоб повернутися до них пізніше.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn-auth-secondary">Назад</a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                var p = item.Pet;

                <div class="col">
                    <div class="card h-100 pet-card">

                        <img src="@(string.IsNullOrEmpty(p.PhotoUrl) 
                            ? "/images/pets/no-photo.svg" 
                            : "/" + p.PhotoUrl.TrimStart('/'))"
                             class="card-img-top pet-img" />

                        <div class="card-body p-0">

                            <div class="d-flex border-top border-bottom border-dark text-center">

                                <!-- Більше -->
                                <a href="/Pets/Details/@p.PetId" class="btn btn-pet-action btn-pet-action--square border-end border-dark">
                                    Переглянути
                                </a>

                                <!-- Видалити -->
                                <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-pet-action btn-pet-action--square text-danger fw-bold">
                                    ❌
                                </a>

                            </div>

                            <div class="p-3 bg-light-yellow text-center">
                                <h5 class="mb-0 fw-bold">@p.PetName, @p.Type, @p.Age @p.AgeText</h5>
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state">
                    <h4 class="empty-state__title">Поки що обране порожнє</h4>
                    <p class="empty-state__text">Додавайте тваринок у ❤️, щоб швидко повертатися до них пізніше.</p>
                </div>
            </div>
        }

    </div>
</section>
