@model Petly.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Створіть новий пароль";
}

<div class="auth-shell">
    <div class="auth-logo-row">
        <span class="logo-text">Petly</span>
    </div>

    <div class="auth-card">
        <h2 class="auth-title">Створіть новий пароль</h2>
        <div class="auth-step-badge">Крок 2 із 2: код і новий пароль</div>
        <p class="auth-description">
            Код уже надіслано на <strong>@Model.Email</strong>. Введіть його нижче разом із новим паролем.
        </p>

        <form asp-action="ResetPassword" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="auth-summary"></div>
            <input asp-for="Email" type="hidden" />

            <div class="text-start">
                <label asp-for="Code" class="form-label fw-semibold">Код із листа</label>
                <input asp-for="Code" class="form-control auth-code-input" autocomplete="one-time-code" />
                <span asp-validation-for="Code" class="field-error"></span>
            </div>

            <div class="text-start">
                <label asp-for="NewPassword" class="form-label fw-semibold">Новий пароль</label>
                <div class="auth-password-field">
                    <input asp-for="NewPassword" class="form-control" />
                    <button type="button" class="auth-toggle-password" data-toggle-password="#NewPassword">Показати</button>
                </div>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="text-start">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold">Підтвердження нового пароля</label>
                <div class="auth-password-field">
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <button type="button" class="auth-toggle-password" data-toggle-password="#ConfirmPassword">Показати</button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-auth-primary">Змінити пароль</button>
        </form>

        <div class="auth-secondary-actions">
            <a class="btn-auth-secondary btn-auth-secondary--soft" asp-action="Login">Назад до входу</a>
            <form asp-action="ResendResetCode" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.Email" />
                <button type="submit" class="auth-link-button">Надіслати код повторно</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
