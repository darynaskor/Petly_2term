@model List<Petly.Models.UserProfile>
@{
    ViewData["Title"] = "Користувачі";
}

<div class="page-header d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="fw-bold mb-1">Користувачі</h2>
        <p class="text-muted mb-0">Нові реєстрації автоматично з'являються у списку.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Register" class="btn-auth-secondary">Нова реєстрація</a>
        <a asp-action="Login" class="btn btn-outline-dark">Сторінка входу</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="table-responsive">
    <table class="table user-table align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>Ім'я</th>
                <th>Прізвище</th>
                <th>Email</th>
                <th>Роль</th>
                <th>Статус</th>
                <th>Зареєстрований</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.AccountId</td>
                    <td>@u.Name</td>
                    <td>@u.Surname</td>
                    <td>@u.Account?.Email</td>
                    <td>@u.Account?.Role</td>
                    <td>@u.Status</td>
                    <td>@u.Account?.RegistrationDate.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@u.AccountId" class="btn btn-sm btn-outline-primary me-2">Редагувати</a>
                        <form asp-action="Delete" asp-route-id="@u.AccountId" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Видалити користувача?');">Видалити</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
