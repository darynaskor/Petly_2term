@model Petly.Models.LoginViewModel
@{
    ViewData["Title"] = "Вхід";
}

<div class="auth-shell">
    <div class="auth-logo-row">
        <span class="logo-text">Petly</span>
    </div>

    <div class="auth-card">
        <h2 class="auth-title">Раді знову бачити!</h2>
        <form asp-action="Login" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="mb-3 text-start">
                <label asp-for="Email" class="form-label fw-semibold">Email:</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3 text-start">
                <label asp-for="Password" class="form-label fw-semibold">Password:</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="form-check mb-3 text-start">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Запам'ятати мене</label>
            </div>
            <button type="submit" class="btn-auth-primary">Увійти</button>
        </form>
        <div class="auth-switch">
            <span>Немає аккаунту?</span>
            <a class="btn-auth-secondary" asp-action="Register">Зареєструватися</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
