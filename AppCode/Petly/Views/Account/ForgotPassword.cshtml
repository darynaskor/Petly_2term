@model Petly.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Відновлення пароля";
}

<div class="auth-shell">
    <div class="auth-logo-row">
        <span class="logo-text">Petly</span>
    </div>

    <div class="auth-card">
        <h2 class="auth-title">Відновлення пароля</h2>
        <div class="auth-step-badge">Крок 1 із 2: введіть email</div>
        <p class="auth-description">
            Введіть електронну пошту, прив’язану до акаунта. Ми надішлемо вам код для відновлення пароля.
        </p>

        <form asp-action="ForgotPassword" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="auth-summary"></div>
            <div class="text-start">
                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <button type="submit" class="btn-auth-primary">Надіслати код</button>
        </form>

        <div class="auth-back-row">
            <a class="btn-auth-secondary btn-auth-secondary--soft" asp-action="Login">Назад до входу</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
