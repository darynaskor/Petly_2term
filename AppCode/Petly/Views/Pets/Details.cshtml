@model Petly.Models.Pet
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Профіль тварини";
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
    var accountId = HttpContextAccessor.HttpContext.Session.GetInt32("AccountId");
}

<h2>@Model.PetName</h2>

<div class="card mb-3" style="max-width: 600px;">
    <div class="row g-0">
        @if (!string.IsNullOrEmpty(Model.PhotoUrl))
        {
            <div class="col-md-4">
                <img src="@Model.PhotoUrl" class="img-fluid rounded-start" alt="@Model.PetName" />
            </div>
        }
        <div class="col-md-8">
            <div class="card-body">
                <p><strong>Тип:</strong> @Model.Type</p>
                <p><strong>Порода:</strong> @Model.Breed</p>
                <p><strong>Стать:</strong> @Model.Gender</p>
                <p><strong>Вік:</strong> @Model.Age @Model.AgeText</p>
                <p><strong>Розмір:</strong> @Model.Size</p>
                <p><strong>Вакцинація:</strong> @(Model.Vaccinated ? "Так" : "Ні")</p>
                <p><strong>Стерилізація:</strong> @(Model.Sterilized ? "Так" : "Ні")</p>
                <p><strong>Опис:</strong> @Model.Description</p>

                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Назад</a>
                <a asp-action="Adopt" asp-route-id="@Model.PetId" class="btn btn-warning"> Адопція</a>

                @if (role == "shelter_admin" && Model.ShelterId == accountId)
                {
                    <a asp-action="Edit" asp-route-id="@Model.PetId" class="btn btn-warning">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@Model.PetId" class="btn btn-danger">Видалити</a>
                }
            </div>
        </div>
    </div>
</div>